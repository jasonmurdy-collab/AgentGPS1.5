rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {
        role: 'agent',
        marketCenterId: null,
        teamId: null,
        isSuperAdmin: false
      };
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getUserData().get('isSuperAdmin', false) == true;
    }
    
    function isOwnerOrManager(data, ownerId) {
      let user = getUserData();
      return isSuperAdmin() ||
             (ownerId != null && request.auth.uid == ownerId) ||
             (data.get('marketCenterId', null) != null && user.marketCenterId == data.marketCenterId && (user.role == 'market_center_admin' || user.role == 'productivity_coach')) ||
             (data.get('teamId', null) != null && user.teamId == data.teamId && user.role == 'team_leader') ||
             (data.get('coachId', null) != null && request.auth.uid == data.coachId);
    }

    function isResourceManager(data) {
      let user = getUserData();
      return isSuperAdmin() ||
             (data.get('marketCenterId', null) != null && user.marketCenterId == data.marketCenterId && (user.role == 'market_center_admin' || user.role == 'productivity_coach')) ||
             (data.get('teamId', null) != null && user.teamId == data.teamId && user.role == 'team_leader');
    }

    function isMCManager(mcId) {
      let user = getUserData();
      return isSuperAdmin() || 
             (isSignedIn() && mcId != null && user.marketCenterId == mcId && (user.role == 'market_center_admin' || user.role == 'productivity_coach' || user.role == 'recruiter'));
    }

    // --- Collection Rules ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isOwnerOrManager(resource.data, userId) || isMCManager(resource.data.get('marketCenterId', null)));
      allow create: if isSignedIn() && request.resource.data.get('isSuperAdmin', false) == false;
      allow update: if isSignedIn() && (
        isSuperAdmin() ||
        (
          (request.auth.uid == userId || isOwnerOrManager(resource.data, userId)) &&
          request.resource.data.get('isSuperAdmin', false) == resource.data.get('isSuperAdmin', false)
        )
      );
      allow delete: if isSuperAdmin();
    }

    // Goals
    match /goals/{goalId} {
      allow read: if isSignedIn() && (
        isOwnerOrManager(resource.data, resource.data.get('userId', null)) || 
        resource.data.get('visibility', 'solo') == 'public'
      );
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
    }

    // Transactions
    match /transactions/{txId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
    }

    // Daily Trackers (Habits)
    match /dailyTrackers/{trackerId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
    }

    // Performance Logs
    match /performanceLogs/{logId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('agentId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('agentId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('agentId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('agentId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('agentId', null));
    }

    // Teams
    match /teams/{teamId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.get('memberIds', []) || 
        isResourceManager(resource.data)
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.get('creatorId', null);
      allow update: if isSignedIn() && (request.auth.uid == resource.data.get('creatorId', null) || isResourceManager(resource.data));
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.get('creatorId', null) || isResourceManager(resource.data));
    }

    // Market Centers
    match /marketCenters/{mcId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid in resource.data.get('adminIds', []));
      allow delete: if isSuperAdmin();
    }

    // Candidates (Recruitment)
    match /candidates/{candidateId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.get('recruiterId', null) || isMCManager(resource.data.get('marketCenterId', null)));
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.get('recruiterId', null) || isMCManager(request.resource.data.get('marketCenterId', null)));
      allow update: if isSignedIn() && (request.auth.uid == resource.data.get('recruiterId', null) || isMCManager(resource.data.get('marketCenterId', null))) && (request.auth.uid == request.resource.data.get('recruiterId', null) || isMCManager(request.resource.data.get('marketCenterId', null)));
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.get('recruiterId', null) || isMCManager(resource.data.get('marketCenterId', null)));
    }

    // Candidate Activities
    match /candidateActivities/{activityId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.get('recruiterId', null) || isMCManager(resource.data.get('marketCenterId', null)));
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.get('recruiterId', null) || isMCManager(request.resource.data.get('marketCenterId', null)));
      allow update: if isSignedIn() && (request.auth.uid == resource.data.get('recruiterId', null) || isMCManager(resource.data.get('marketCenterId', null))) && (request.auth.uid == request.resource.data.get('recruiterId', null) || isMCManager(request.resource.data.get('marketCenterId', null)));
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.get('recruiterId', null) || isMCManager(resource.data.get('marketCenterId', null)));
    }

    // Client Leads
    match /clientLeads/{leadId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('ownerId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('ownerId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('ownerId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('ownerId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('ownerId', null));
    }

    // Client Lead Activities
    match /clientLeadActivities/{activityId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('ownerId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('ownerId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('ownerId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('ownerId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('ownerId', null));
    }
    
    // Todos
    match /todos/{todoId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.get('userId', null);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.get('userId', null);
      allow update: if isSignedIn() && request.auth.uid == resource.data.get('userId', null) && request.auth.uid == request.resource.data.get('userId', null);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.get('userId', null);
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if isSignedIn() && (resource.data.get('marketCenterId', null) == null || resource.data.get('marketCenterId', null) == getUserData().marketCenterId);
      allow create: if isSignedIn() && isResourceManager(request.resource.data);
      allow update: if isSignedIn() && isResourceManager(resource.data) && isResourceManager(request.resource.data);
      allow delete: if isSignedIn() && isResourceManager(resource.data);
    }

    // Playbooks and Learning Paths
    match /playbooks/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isResourceManager(request.resource.data);
      allow update: if isSignedIn() && isResourceManager(resource.data) && isResourceManager(request.resource.data);
      allow delete: if isSignedIn() && isResourceManager(resource.data);
    }
    
    match /learningPaths/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isResourceManager(request.resource.data);
      allow update: if isSignedIn() && isResourceManager(resource.data) && isResourceManager(request.resource.data);
      allow delete: if isSignedIn() && isResourceManager(resource.data);
    }

    // User Submissions (LMS)
    match /submissions/{subId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.get('userId', null);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.get('userId', null);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.get('userId', null);
    }

    // Commission Profiles
    match /commissionProfiles/{profileId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, profileId);
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, profileId);
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, profileId) && isOwnerOrManager(request.resource.data, profileId);
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, profileId);
    }

    // Budget Models
    match /budgetModels/{modelId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null)) && isOwnerOrManager(request.resource.data, request.resource.data.get('userId', null));
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, resource.data.get('userId', null));
    }

    // Live Sessions
    match /liveSessions/{sessionId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() || 
        resource.data.get('marketCenterId', null) == null ||
        resource.data.get('marketCenterId', null) == getUserData().marketCenterId || 
        (request.auth.token.email in resource.data.get('attendees', []))
      );
      allow create: if isSignedIn() && isResourceManager(request.resource.data);
      allow update: if isSignedIn() && isResourceManager(resource.data) && isResourceManager(request.resource.data);
      allow delete: if isSignedIn() && isResourceManager(resource.data);
    }

    // User Integrations
    match /userIntegrations/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Business GPS
    match /businessGps/{userId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, userId);
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, userId);
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, userId) && isOwnerOrManager(request.resource.data, userId);
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, userId);
    }

    // Habit Tracker Templates
    match /habitTrackerTemplates/{templateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isResourceManager(request.resource.data);
      allow update: if isSignedIn() && isResourceManager(resource.data) && isResourceManager(request.resource.data);
      allow delete: if isSignedIn() && isResourceManager(resource.data);
    }

    // Organizational Blueprints
    match /orgBlueprints/{userId} {
      allow read: if isSignedIn() && isOwnerOrManager(resource.data, userId);
      allow create: if isSignedIn() && isOwnerOrManager(request.resource.data, userId);
      allow update: if isSignedIn() && isOwnerOrManager(resource.data, userId) && isOwnerOrManager(request.resource.data, userId);
      allow delete: if isSignedIn() && isOwnerOrManager(resource.data, userId);
    }
  }
}
