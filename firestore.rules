rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getUserData().isSuperAdmin == true;
    }
    
    function isMcAdmin(mcId) {
      let user = getUserData();
      return isSuperAdmin() || (user.role == 'market_center_admin' && user.marketCenterId == mcId);
    }

    function canManageAgent(agentData, agentId) {
      let user = getUserData();
      return isSuperAdmin() || 
             (user.role == 'market_center_admin' && user.marketCenterId == agentData.marketCenterId) || 
             (user.role == 'productivity_coach' && user.marketCenterId == agentData.marketCenterId) ||
             (request.auth.uid == agentData.coachId) ||
             (user.role == 'team_leader' && user.teamId != null && user.teamId == agentData.teamId);
    }

    function canManageMCResources(mcId) {
      let user = getUserData();
      return isSuperAdmin() || 
             (isSignedIn() && user.marketCenterId == mcId && (user.role == 'market_center_admin' || user.role == 'productivity_coach'));
    }

    // --- Collection Rules ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || canManageAgent(resource.data, userId));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        isMcAdmin(resource.data.marketCenterId) || 
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Goals
    match /goals/{goalId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        isMcAdmin(resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.userId)).data, resource.data.userId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        isMcAdmin(request.resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data, request.resource.data.userId)
      );
    }

    // Transactions
    match /transactions/{txId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        isMcAdmin(resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.userId)).data, resource.data.userId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        isMcAdmin(request.resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data, request.resource.data.userId)
      );
    }

    // Daily Trackers (Habits)
    match /dailyTrackers/{trackerId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        isMcAdmin(resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.userId)).data, resource.data.userId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        isMcAdmin(request.resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data, request.resource.data.userId)
      );
    }

    // Performance Logs
    match /performanceLogs/{logId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.agentId || 
        isMcAdmin(resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.agentId)).data, resource.data.agentId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.coachId || 
        isMcAdmin(request.resource.data.marketCenterId) ||
        canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.agentId)).data, resource.data.agentId)
      );
    }

    // Teams
    match /teams/{teamId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds || 
        isMcAdmin(resource.data.marketCenterId) ||
        (getUserData().role == 'productivity_coach' && getUserData().marketCenterId == resource.data.marketCenterId)
      );
      allow write: if isSignedIn() && (request.auth.uid == resource.data.creatorId || isMcAdmin(resource.data.marketCenterId));
    }

    // Market Centers
    match /marketCenters/{mcId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid in resource.data.adminIds);
    }

    // Candidates (Recruitment)
    match /candidates/{candidateId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.recruiterId || isMcAdmin(resource.data.marketCenterId));
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.recruiterId || isMcAdmin(request.resource.data.marketCenterId));
    }

    // Client Leads
    match /clientLeads/{leadId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.ownerId || canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.ownerId)).data, resource.data.ownerId));
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.ownerId || canManageAgent(get(/databases/$(database)/documents/users/$(request.resource.data.ownerId)).data, request.resource.data.ownerId));
    }
    
    // Todos
    match /todos/{todoId} {
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if isSignedIn() && (resource.data.marketCenterId == null || resource.data.marketCenterId == getUserData().marketCenterId);
      allow write: if isSignedIn() && isMcAdmin(request.resource.data.marketCenterId);
    }

    // Playbooks and Learning Paths
    match /playbooks/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (canManageMCResources(request.resource.data.marketCenterId) || canManageMCResources(resource.data.marketCenterId) || isSuperAdmin());
    }
    
    match /learningPaths/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (canManageMCResources(request.resource.data.marketCenterId) || canManageMCResources(resource.data.marketCenterId) || isSuperAdmin());
    }

    // User Submissions (LMS)
    match /userSubmissions/{subId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.userId)).data, resource.data.userId));
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.userId || canManageAgent(get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data, request.resource.data.userId));
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow write: if isSignedIn();
    }

    // Commission Profiles
    match /commissionProfiles/{profileId} {
      allow read: if isSignedIn() && (request.auth.uid == profileId || isMcAdmin(resource.data.marketCenterId) || canManageAgent(get(/databases/$(database)/documents/users/$(profileId)).data, profileId));
      allow write: if isSignedIn() && (request.auth.uid == profileId || isMcAdmin(resource.data.marketCenterId));
    }

    // Budget Models
    match /budgetModels/{modelId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isMcAdmin(resource.data.marketCenterId) || canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.userId)).data, resource.data.userId));
      allow write: if isSignedIn() && (request.auth.uid == resource.data.userId || isMcAdmin(resource.data.marketCenterId) || canManageAgent(get(/databases/$(database)/documents/users/$(resource.data.userId)).data, resource.data.userId));
    }

    // Live Sessions
    match /{path=**}/liveSessions/{sessionId} {
      allow read: if isSignedIn() && (resource.data.marketCenterId == getUserData().marketCenterId || isSuperAdmin());
      allow write: if isSignedIn() && (resource.data.marketCenterId == getUserData().marketCenterId || isSuperAdmin());
    }

    // Business GPS
    match /businessGps/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || canManageAgent(get(/databases/$(database)/documents/users/$(userId)).data, userId));
      allow write: if isSignedIn() && (request.auth.uid == userId || isMcAdmin(get(/databases/$(database)/documents/users/$(userId)).data.marketCenterId));
    }

    // Habit Tracker Templates
    match /habitTrackerTemplates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && isMcAdmin(request.resource.data.marketCenterId));
    }

    // Organizational Blueprints
    match /orgBlueprints/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || canManageAgent(get(/databases/$(database)/documents/users/$(userId)).data, userId));
      allow write: if isSignedIn() && (request.auth.uid == userId || isMcAdmin(get(/databases/$(database)/documents/users/$(userId)).data.marketCenterId));
    }
  }
}
