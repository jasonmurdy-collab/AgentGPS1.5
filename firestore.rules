rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {
        role: 'agent',
        marketCenterId: null,
        teamId: null,
        isSuperAdmin: false
      };
    }
    
    function isSuperAdmin() {
      return isSignedIn() && getUserData().get('isSuperAdmin', false) == true;
    }
    
    function canManageAgent(agentData, agentId) {
      let user = getUserData();
      return isSuperAdmin() || 
             (request.auth.uid == agentId) ||
             (user.role == 'market_center_admin' && user.marketCenterId == agentData.marketCenterId) || 
             (user.role == 'productivity_coach' && user.marketCenterId == agentData.marketCenterId) ||
             (user.role == 'recruiter' && user.marketCenterId == agentData.marketCenterId) ||
             (request.auth.uid == agentData.get('coachId', null)) ||
             (user.role == 'team_leader' && user.teamId != null && user.teamId == agentData.teamId);
    }

    function canManageMCResources(mcId) {
      let user = getUserData();
      return isSuperAdmin() || 
             (isSignedIn() && mcId != null && user.marketCenterId == mcId && (user.role == 'market_center_admin' || user.role == 'productivity_coach'));
    }

    function isMCManager(mcId) {
      let user = getUserData();
      return isSuperAdmin() || 
             (isSignedIn() && mcId != null && user.marketCenterId == mcId && (user.role == 'market_center_admin' || user.role == 'productivity_coach' || user.role == 'recruiter'));
    }

    // --- Collection Rules ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || canManageAgent(resource.data, userId));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        canManageAgent(resource.data, userId) ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // Goals
    match /goals/{goalId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        resource.data.get('visibility', 'solo') == 'public' ||
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        canManageMCResources(request.resource.data.marketCenterId) ||
        request.auth.uid == request.resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.teamId)
      );
    }

    // Transactions
    match /transactions/{txId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        canManageMCResources(request.resource.data.marketCenterId) ||
        request.auth.uid == request.resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.teamId)
      );
    }

    // Daily Trackers (Habits)
    match /dailyTrackers/{trackerId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        canManageMCResources(request.resource.data.marketCenterId) ||
        request.auth.uid == request.resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.teamId)
      );
    }

    // Performance Logs
    match /performanceLogs/{logId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.agentId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.coachId || 
        canManageMCResources(request.resource.data.marketCenterId) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.teamId)
      );
    }

    // Teams
    match /teams/{teamId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds || 
        canManageMCResources(resource.data.marketCenterId)
      );
      allow write: if isSignedIn() && (request.auth.uid == resource.data.creatorId || canManageMCResources(resource.data.marketCenterId));
    }

    // Market Centers
    match /marketCenters/{mcId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid in resource.data.adminIds);
    }

    // Candidates (Recruitment)
    match /candidates/{candidateId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.recruiterId || isMCManager(resource.data.marketCenterId));
      allow write: if isSignedIn() && (request.auth.uid == request.resource.data.recruiterId || isMCManager(request.resource.data.marketCenterId) || (resource != null && isMCManager(resource.data.marketCenterId)));
    }

    // Candidate Activities
    match /candidateActivities/{activityId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.get('recruiterId', null) ||
        isMCManager(resource.data.get('marketCenterId', null))
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.get('recruiterId', null) ||
        isMCManager(request.resource.data.get('marketCenterId', null))
      );
    }

    // Client Leads
    match /clientLeads/{leadId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.ownerId || 
        canManageMCResources(request.resource.data.marketCenterId) ||
        request.auth.uid == request.resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.teamId)
      );
    }

    // Client Lead Activities
    match /clientLeadActivities/{activityId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.get('ownerId', null) ||
        canManageMCResources(resource.data.get('marketCenterId', null)) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.get('teamId', null))
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.get('ownerId', null) ||
        canManageMCResources(request.resource.data.get('marketCenterId', null)) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.get('teamId', null))
      );
    }
    
    // Todos
    match /todos/{todoId} {
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if isSignedIn() && (resource.data.marketCenterId == null || resource.data.marketCenterId == getUserData().marketCenterId);
      allow write: if isSignedIn() && canManageMCResources(request.resource.data.marketCenterId);
    }

    // Playbooks and Learning Paths
    match /playbooks/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (canManageMCResources(request.resource.data.marketCenterId) || canManageMCResources(resource.data.marketCenterId) || isSuperAdmin());
    }
    
    match /learningPaths/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (canManageMCResources(request.resource.data.marketCenterId) || canManageMCResources(resource.data.marketCenterId) || isSuperAdmin());
    }

    // User Submissions (LMS)
    match /submissions/{subId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId || 
        canManageMCResources(request.resource.data.marketCenterId) ||
        request.auth.uid == request.resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == request.resource.data.teamId)
      );
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow write: if isSignedIn();
    }

    // Commission Profiles
    match /commissionProfiles/{profileId} {
      allow read: if isSignedIn() && (
        request.auth.uid == profileId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (request.auth.uid == profileId || canManageMCResources(resource.data.marketCenterId) || request.auth.uid == resource.data.get('coachId', null));
    }

    // Budget Models
    match /budgetModels/{modelId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
    }

    // Live Sessions
    match /liveSessions/{sessionId} {
      allow read: if isSignedIn() && (
        (resource.data.marketCenterId != null && resource.data.marketCenterId == getUserData().marketCenterId) || 
        isSuperAdmin() || 
        (request.auth.token.email in resource.data.get('attendees', []))
      );
      allow write: if isSignedIn() && (canManageMCResources(request.resource.data.marketCenterId) || isSuperAdmin() || (resource != null && canManageMCResources(resource.data.marketCenterId)));
    }

    // User Integrations
    match /userIntegrations/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Business GPS
    match /businessGps/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (request.auth.uid == userId || canManageMCResources(get(/databases/$(database)/documents/users/$(userId)).data.marketCenterId) || request.auth.uid == get(/databases/$(database)/documents/users/$(userId)).data.get('coachId', null));
    }

    // Habit Tracker Templates
    match /habitTrackerTemplates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && canManageMCResources(request.resource.data.marketCenterId));
    }

    // Organizational Blueprints
    match /orgBlueprints/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        canManageMCResources(resource.data.marketCenterId) ||
        request.auth.uid == resource.data.get('coachId', null) ||
        (getUserData().role == 'team_leader' && getUserData().teamId != null && getUserData().teamId == resource.data.teamId)
      );
      allow write: if isSignedIn() && (request.auth.uid == userId || canManageMCResources(get(/databases/$(database)/documents/users/$(userId)).data.marketCenterId) || request.auth.uid == get(/databases/$(database)/documents/users/$(userId)).data.get('coachId', null));
    }
  }
}
